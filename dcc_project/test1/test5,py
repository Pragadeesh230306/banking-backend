@app.route("/mini-statement/<acc>")
def mini_statement(acc):
    conn = get_db()
    cursor = conn.cursor()

    cursor.execute("""
        SELECT * FROM transactions
        WHERE from_account=? OR to_account=?
        ORDER BY created_at DESC LIMIT 10
    """, (acc, acc))

    rows = cursor.fetchall()

    return jsonify([dict(r) for r in rows])

